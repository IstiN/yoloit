#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────
# yoloit — CLI client for the YoLoIT desktop app
#
# Communicates with the in-app HTTP server on localhost via curl.
# The server writes its port to ~/.config/yoloit/cli.port on startup.
# ──────────────────────────────────────────────────────────────────────
set -euo pipefail

PORT_FILE="${HOME}/.config/yoloit/cli.port"
STATE_FILE="${HOME}/.config/yoloit/state.json"
BASE=""

_board() {
  local val="${1:-}"
  if [[ -n "$val" ]]; then echo "$val"; return; fi
  if [[ ! -f "$STATE_FILE" ]]; then return; fi
  python3 -c "import json,sys; f=sys.argv[1]; print(json.load(open(f)).get('board',''))" "$STATE_FILE" 2>/dev/null || true
}

_use_board() {
  mkdir -p "$(dirname "$STATE_FILE")" 2>/dev/null || true
  python3 -c "
import json, sys, os
f = sys.argv[1]
d = json.load(open(f)) if os.path.exists(f) else {}
d['board'] = sys.argv[2]
open(f, 'w').write(json.dumps(d))
" "$STATE_FILE" "$1" 2>/dev/null || true
}

_resolve_base() {
  if [[ -n "$BASE" ]]; then return; fi
  if [[ -n "${YOLOIT_CLI_PORT:-}" ]]; then
    BASE="http://127.0.0.1:${YOLOIT_CLI_PORT}/api"
    return
  fi
  if [[ ! -f "$PORT_FILE" ]]; then
    echo "Error: YoLoIT is not running (no port file at $PORT_FILE)" >&2
    exit 1
  fi
  local port
  port=$(cat "$PORT_FILE")
  BASE="http://127.0.0.1:${port}/api"
}

_curl() {
  _resolve_base
  local method=$1 path=$2
  shift 2
  curl -s -X "$method" "${BASE}${path}" \
    -H "Content-Type: application/json" "$@"
}

_get()    { _curl GET    "$1"; }
_post()   { _curl POST   "$1" -d "${2:-\{\}}"; }
_put()    { _curl PUT    "$1" -d "${2:-\{\}}"; }
_delete() { _curl DELETE "$1"; }

