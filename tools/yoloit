        await ws.send(json.dumps({"jsonrpc":"2.0","id":"2","method":"reloadSources","params":{"isolateId": isolate_id}}))
        result = json.loads(await ws.recv())
        t = result.get("result",{}).get("type","")
        if t == "ReloadReport":
            print("✅ Hot reload complete")
        else:
            print("⚠️", json.dumps(result))

asyncio.run(reload(sys.argv[1]))
