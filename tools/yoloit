import subprocess, re, sys, json, os

script_path = sys.argv[1] if len(sys.argv) > 1 else os.path.realpath(__file__)

# Get all registered commands + aliases via registry format
result = subprocess.run([script_path, 'help', '--format', 'registry'],
                        capture_output=True, text=True)
if result.returncode != 0:
    print("❌ Could not load registry:", result.stderr, file=sys.stderr)
    sys.exit(1)

registry = json.loads(result.stdout)

# All names expected to have a bash handler
expected = set()
for entry in registry:
    expected.add(entry["name"])
    for a in entry.get("aliases", []):
        expected.add(a)

# Commands handled implicitly (not needing their own case branch)
implicit = {
    "help", "--help", "-h",
    "validate",
    "boards", "panels", "links",  # simple pass-through
    "*",  # catch-all
}

# Parse bash case patterns from the script source
with open(script_path) as f:
    source = f.read()

bash_cmds = set()
in_case = False
case_depth = 0
for line in source.split("\n"):
    stripped = line.strip()
    # Detect the top-level command dispatch case
    if not in_case and stripped == 'case "$cmd" in':
        in_case = True
        case_depth = 1
        continue
    if in_case:
        # Track nested case...esac blocks
        if re.match(r'^case\b', stripped):
            case_depth += 1
        elif stripped == "esac":
            case_depth -= 1
            if case_depth == 0:
                break  # Done with top-level case
            continue
        # Only match patterns at depth 1 (top-level dispatch)
        if case_depth == 1:
            m = re.match(r'^([\w:.\-|]+)\)$', stripped)
            if m:
                for pat in m.group(1).split("|"):
                    bash_cmds.add(pat.strip())

missing_bash = expected - bash_cmds - implicit
missing_registry = bash_cmds - expected - implicit

errors = 0
warnings = 0

if missing_bash:
    print("❌ In registry but no bash case handler:")
    for cmd in sorted(missing_bash):
        print(f"   add to bash case: {cmd})")
    errors += len(missing_bash)

if missing_registry:
    print("⚠️  Bash case handler but not in registry (consider adding to commands[]):")
    for cmd in sorted(missing_registry):
        print(f"   {cmd}")
    warnings += len(missing_registry)

# Alias collision check
alias_map = {}
for entry in registry:
    for a in entry.get("aliases", []):
        if a in alias_map:
            print(f"❌ Alias collision: '{a}' used by both '{alias_map[a]}' and '{entry['name']}'")
            errors += 1
        else:
            alias_map[a] = entry["name"]

