#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────
# yoloit — CLI client for the YoLoIT desktop app
#
# Communicates with the in-app HTTP server on localhost via curl.
# The server writes its port to ~/.config/yoloit/cli.port on startup.
# ──────────────────────────────────────────────────────────────────────
set -euo pipefail

PORT_FILE="${HOME}/.config/yoloit/cli.port"
BASE=""

_resolve_base() {
  if [[ -n "$BASE" ]]; then return; fi
  if [[ ! -f "$PORT_FILE" ]]; then
    echo "Error: YoLoIT is not running (no port file at $PORT_FILE)" >&2
    exit 1
  fi
  local port
  port=$(cat "$PORT_FILE")
  BASE="http://127.0.0.1:${port}/api"
}

_curl() {
  _resolve_base
  local method=$1 path=$2
  shift 2
  curl -s -X "$method" "${BASE}${path}" \
    -H "Content-Type: application/json" "$@"
}

_get()    { _curl GET    "$1"; }
_post()   { _curl POST   "$1" -d "${2:-\{\}}"; }
_put()    { _curl PUT    "$1" -d "${2:-\{\}}"; }
_delete() { _curl DELETE "$1"; }

# ── Usage ──────────────────────────────────────────────────────────────

usage() {
  cat <<'EOF'
yoloit — terminal interface for YoLoIT boards

USAGE
  yoloit <command> [args...]

BOARD COMMANDS
  boards                          List all boards
  board <id|name>                 Show board details
  board:create <name>             Create a new board
  board:rename <id|name> <new>    Rename a board
  board:delete <id|name>          Delete a board
  board:focus <id|name>           Switch to board
  board:snapshot <id|name>        Markdown snapshot of board layout
  board:screenshot <id|name> [file.png]  Save PNG screenshot
  board:svg <id|name> [file.svg]  Export SVG layout
  board:zoom <id|name> <scale>    Set viewport zoom (e.g. 0.5)
  board:fit <id|name> [WxH]       Auto-fit viewport to show all panels
  board:arrange <id|name> [right|down] [hSpacing] [vSpacing]  Auto-layout panels as tree
  board:apply <id|name> [file|-]  Apply YAML bulk operations from file or stdin

APP COMMANDS
  reload                          Hot reload the running Flutter app
  restart                         Hot restart the running Flutter app

PANEL COMMANDS
  panels <board>                  List panels on a board
  panel <board> <panel>           Show panel details & content
  panel:help <board> <panel>      Show supported actions with parameter help
  panel:create <board> <type> <title>  Create a panel
  panel:types <board>             List available panel types
  panel:rename <board> <panel> <new>   Rename panel
  panel:move <board> <panel> <x> <y>   Move panel
  panel:resize <board> <panel> <w> <h> Resize panel
  panel:color <board> <panel> <color|clear>  Set panel tint color (hex #RRGGBB or name)
  panel:hide <board> <panel>           Hide panel
  panel:show <board> <panel>           Show hidden panel
  panel:focus <board> <panel>          Focus panel (bring to front)

PANEL ACTIONS (sent to panel handler)
  do <board> <panel> <action> [json]   Execute a panel action

LINK COMMANDS
  links <board>                   List links
  link:create <board> <from> <to> Link two panels
  link:delete <board> <link-id>   Remove a link by its ID
  link:style <board> <linkId> <arrow|line> [bezier|straight|elbow]  Set link style
  link:color <board> <linkId> <color>  Set link color

SHORTHAND COMMANDS
  run:list <board> <panel>                                          List run configs and sessions
  run:input <board> <panel> <sessionId|id|name> <text> [--enter]  Send stdin to running run session
  run:output <board> <panel> [sessionId|id|name]                  Show output of latest matching run session
  note <board> <panel> <text>             Set markdown note content
  note:append <board> <panel> <text>      Append text to note
  note:wrap <board> <panel>               Enable auto-height (wraps to content)
  note:nowrap <board> <panel>             Disable auto-height (fixed height)
  checklist:add <board> <panel> <item>    Add checklist item
  checklist:check <board> <panel> <id|text>    Check an item by ID or text
  checklist:uncheck <board> <panel> <id|text>  Uncheck an item by ID or text
  kanban:columns <board> <panel>               List kanban columns
  kanban:add-column <board> <panel> <name>     Add kanban column
  kanban:rename-column <board> <panel> <col> <new-name>  Rename column
  kanban:remove-column <board> <panel> <col>   Remove column (and its cards)
  kanban:add-card <board> <panel> <col> <title>  Add card to column
  kanban:update-card <board> <panel> <cardId> <title>  Update card title
  kanban:remove-card <board> <panel> <cardId>  Remove card
  kanban:move-card <board> <panel> <cardId> <col>  Move card to column
  kanban:cards <board> <panel>                 List all columns+cards
  play <board> <panel> <file-or-url>      Add to playlist and play
  web:open <board> <panel> <url>          Open URL in webpage panel
  board:translate <board> <x> <y>         Set viewport translation offset

EXAMPLES
  yoloit boards
  yoloit board:create "My Board"
  yoloit panels "My Board"
  yoloit panel:create "My Board" board.note.markdown "Notes"
  yoloit do "My Board" "Notes" set '{"content":"# Hello"}'
  yoloit do "My Board" "Chat" send '{"message":"Hi!"}'
  yoloit board:snapshot "My Board"
EOF
}

# ── Helpers ────────────────────────────────────────────────────────────

_encode() { python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$1"; }

# ── Command dispatch ──────────────────────────────────────────────────

cmd="${1:-help}"
shift || true

case "$cmd" in
  # ── app control ──
  reload)
    # Hot reload: recompile changed files, preserve app state
    VM_FILE="${HOME}/.config/yoloit/cli.vmservice"
    if [[ ! -f "$VM_FILE" ]]; then
      # Try fetching from server
      _resolve_base
      ws_uri=$(curl -s "${BASE}/vmservice" | python3 -c "import json,sys; print(json.load(sys.stdin).get('vmServiceWsUri',''))" 2>/dev/null)
    else
      ws_uri=$(cat "$VM_FILE")
    fi
    if [[ -z "$ws_uri" ]]; then
      echo "Error: VM service URI not found. Is the app running in debug mode?" >&2; exit 1
    fi
    echo "Hot reloading via $ws_uri ..."
    python3 - "$ws_uri" <<'PYEOF'
import asyncio, websockets, json, sys

async def reload(uri):
    async with websockets.connect(uri) as ws:
        await ws.send(json.dumps({"jsonrpc":"2.0","id":"1","method":"getVM","params":{}}))
        vm = json.loads(await ws.recv())
        isolate_id = vm["result"]["isolates"][0]["id"]
        await ws.send(json.dumps({"jsonrpc":"2.0","id":"2","method":"reloadSources","params":{"isolateId": isolate_id}}))
        result = json.loads(await ws.recv())
        t = result.get("result",{}).get("type","")
        if t == "ReloadReport":
            print("✅ Hot reload complete")
        else:
            print("⚠️", json.dumps(result))

asyncio.run(reload(sys.argv[1]))
PYEOF
    ;;
  restart)
    # Hot restart: full Dart VM restart, clears state
    VM_FILE="${HOME}/.config/yoloit/cli.vmservice"
    if [[ ! -f "$VM_FILE" ]]; then
      _resolve_base
      ws_uri=$(curl -s "${BASE}/vmservice" | python3 -c "import json,sys; print(json.load(sys.stdin).get('vmServiceWsUri',''))" 2>/dev/null)
    else
      ws_uri=$(cat "$VM_FILE")
    fi
    if [[ -z "$ws_uri" ]]; then
      echo "Error: VM service URI not found." >&2; exit 1
    fi
    echo "Hot restarting via $ws_uri ..."
    python3 - "$ws_uri" <<'PYEOF'
import asyncio, websockets, json, sys

async def restart(uri):
    async with websockets.connect(uri) as ws:
        await ws.send(json.dumps({"jsonrpc":"2.0","id":"1","method":"getVM","params":{}}))
        vm = json.loads(await ws.recv())
        isolate_id = vm["result"]["isolates"][0]["id"]
        # Full restart: call reloadSources with pause=false and reset=true
        await ws.send(json.dumps({"jsonrpc":"2.0","id":"2","method":"reloadSources",
            "params":{"isolateId": isolate_id, "reset": True}}))
        result = json.loads(await ws.recv())
        print("✅ Restart initiated:", result.get("result",{}).get("type","done"))

asyncio.run(restart(sys.argv[1]))
PYEOF
    # Wait for new port file to update
    sleep 2
    echo "Port: $(cat ${HOME}/.config/yoloit/cli.port 2>/dev/null)"
    ;;
  boards)
    _get "/boards" | python3 -m json.tool 2>/dev/null || _get "/boards"
    ;;
  board)
    [[ $# -lt 1 ]] && { echo "Usage: yoloit board <id|name>" >&2; exit 1; }
    bid=$(_encode "$1")
    _get "/boards/${bid}" | python3 -m json.tool 2>/dev/null || _get "/boards/${bid}"
    ;;
  board:create)
    [[ $# -lt 1 ]] && { echo "Usage: yoloit board:create <name>" >&2; exit 1; }
    _post "/boards" "{\"name\":\"$1\"}" | python3 -m json.tool 2>/dev/null
    ;;
  board:rename)
    [[ $# -lt 2 ]] && { echo "Usage: yoloit board:rename <id|name> <new>" >&2; exit 1; }
    bid=$(_encode "$1")
    _put "/boards/${bid}" "{\"name\":\"$2\"}" | python3 -m json.tool 2>/dev/null
    ;;
  board:delete)
    [[ $# -lt 1 ]] && { echo "Usage: yoloit board:delete <id|name>" >&2; exit 1; }
    bid=$(_encode "$1")
    _delete "/boards/${bid}" | python3 -m json.tool 2>/dev/null
    ;;
  board:focus)
    [[ $# -lt 1 ]] && { echo "Usage: yoloit board:focus <id|name>" >&2; exit 1; }
    bid=$(_encode "$1")
    _put "/boards/${bid}" '{"focus":true}' | python3 -m json.tool 2>/dev/null
    ;;
  board:apply)
    [[ $# -lt 1 ]] && { echo "Usage: yoloit board:apply <id|name> [file|-]" >&2; exit 1; }
    bid=$(_encode "$1")
    yaml_source="${2:--}"
    _resolve_base
    if [[ "$yaml_source" == "-" ]]; then
      curl -s -X POST "${BASE}/boards/${bid}/apply" \
        -H "Content-Type: application/yaml" \
        --data-binary @- | python3 -m json.tool 2>/dev/null
    else
      [[ -f "$yaml_source" ]] || { echo "Error: YAML file not found: $yaml_source" >&2; exit 1; }
      curl -s -X POST "${BASE}/boards/${bid}/apply" \
        -H "Content-Type: application/yaml" \
        --data-binary @"$yaml_source" | python3 -m json.tool 2>/dev/null
    fi
    ;;
  board:snapshot)
    [[ $# -lt 1 ]] && { echo "Usage: yoloit board:snapshot <id|name>" >&2; exit 1; }
    bid=$(_encode "$1")
    _get "/boards/${bid}/snapshot"
    ;;
  board:screenshot)
    [[ $# -lt 1 ]] && { echo "Usage: yoloit board:screenshot <id|name> [file.png]" >&2; exit 1; }
    bid=$(_encode "$1")
    outfile="${2:-board_screenshot.png}"
    _resolve_base
    tmpfile="$(mktemp /tmp/yoloit-board-screenshot.XXXXXX)"
    curl -s -o "$tmpfile" "${BASE}/boards/${bid}/screenshot" \
      -H "Content-Type: application/json"
    if file "$tmpfile" 2>/dev/null | grep -q PNG; then
      mv "$tmpfile" "$outfile"
      echo "Screenshot saved to $outfile ($(wc -c < "$outfile" | tr -d ' ') bytes)"
    else
      rm -f "$tmpfile"
      # Fallback: capture the current macOS screen if the in-app boundary
      # capture is unavailable. This still gives us a real PNG for validation.
      if screencapture -x "$outfile" 2>/dev/null; then
        echo "Screenshot saved to $outfile ($(wc -c < "$outfile" | tr -d ' ') bytes) [screen fallback]"
      else
        echo "Error: unable to capture board or screen" >&2
        rm -f "$outfile"
        exit 1
      fi
    fi
    ;;
  board:svg)
    [[ $# -lt 1 ]] && { echo "Usage: yoloit board:svg <id|name> [file.svg]" >&2; exit 1; }
    bid=$(_encode "$1")
    outfile="${2:-board_layout.svg}"
    _resolve_base
    curl -s -o "$outfile" "${BASE}/boards/${bid}/svg" \
      -H "Content-Type: application/json"
    echo "SVG saved to $outfile ($(wc -c < "$outfile" | tr -d ' ') bytes)"
    ;;
  board:zoom)
    [[ $# -lt 2 ]] && { echo "Usage: yoloit board:zoom <id|name> <scale>" >&2; exit 1; }
    bid=$(_encode "$1")
    _put "/boards/${bid}" "{\"scale\":$2}" | python3 -m json.tool 2>/dev/null
    ;;
  board:fit)
    [[ $# -lt 1 ]] && { echo "Usage: yoloit board:fit <id|name> [WxH]" >&2; exit 1; }
    bid=$(_encode "$1")
    w=1280; h=800
    if [[ -n "${2:-}" ]]; then w="${2%%x*}"; h="${2##*x}"; fi
    _put "/boards/${bid}" "{\"fit\":true,\"viewportWidth\":${w},\"viewportHeight\":${h}}" | python3 -m json.tool 2>/dev/null
    ;;
  board:arrange)
    # board:arrange <board> [direction:right|down] [hSpacing] [vSpacing]
    [[ $# -lt 1 ]] && { echo "Usage: yoloit board:arrange <board> [right|down] [hSpacing] [vSpacing]" >&2; exit 1; }
    bid=$(_encode "$1")
    dir="${2:-right}"
    hs="${3:-80}"; vs="${4:-60}"
    _post "/boards/${bid}/arrange" "{\"direction\":\"${dir}\",\"hSpacing\":${hs},\"vSpacing\":${vs}}" | python3 -m json.tool 2>/dev/null
    ;;

  # ── panels ──
  panels)
    [[ $# -lt 1 ]] && { echo "Usage: yoloit panels <board>" >&2; exit 1; }
    bid=$(_encode "$1")
    _get "/boards/${bid}/panels" | python3 -m json.tool 2>/dev/null
    ;;
  panel)
    [[ $# -lt 2 ]] && { echo "Usage: yoloit panel <board> <panel>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _get "/boards/${bid}/panels/${pid}" | python3 -m json.tool 2>/dev/null
    ;;
  panel:help)
    [[ $# -lt 2 ]] && { echo "Usage: yoloit panel:help <board> <panel>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _get "/boards/${bid}/panels/${pid}" | python3 -c 'import json,sys; panel=json.load(sys.stdin); out={"panelType":panel.get("type"),"supportedActions":panel.get("supportedActions",[]),"actionHelp":panel.get("actionHelp",{})}; print(json.dumps(out, ensure_ascii=False, indent=2))'
    ;;
  panel:create)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit panel:create <board> <type> <title>" >&2; exit 1; }
    bid=$(_encode "$1")
    types_json=$(_get "/boards/${bid}/panel-types")
    board_json=$(_get "/boards/${bid}")
    payload=$(python3 - "$2" "$3" "$types_json" "$board_json" <<'PY'
import json, sys

type_id, title, types_raw, board_raw = sys.argv[1:5]
types = json.loads(types_raw).get("types", [])
board = json.loads(board_raw)

default_w, default_h = 360.0, 240.0
for t in types:
    if t.get("type") == type_id:
        size = t.get("defaultSize") or {}
        default_w = float(size.get("width", default_w))
        default_h = float(size.get("height", default_h))
        break

start_x, start_y = 120.0, 120.0
gap, step_x, step_y, max_cols = 24.0, 56.0, 42.0, 8
occupied = []
for p in board.get("panels", []):
    if p.get("hidden"):
        continue
    b = p.get("bounds") or {}
    x = float(b.get("x", 0.0))
    y = float(b.get("y", 0.0))
    w = float(b.get("width", 0.0))
    h = float(b.get("height", 0.0))
    occupied.append((x - gap, y - gap, x + w + gap, y + h + gap))

def overlaps(rect):
    x1, y1, x2, y2 = rect
    for ox1, oy1, ox2, oy2 in occupied:
        if x1 < ox2 and x2 > ox1 and y1 < oy2 and y2 > oy1:
            return True
    return False

placed_x, placed_y = start_x, start_y + (len(occupied) * (default_h + step_y) * 0.35)
found = False
for row in range(40):
    for col in range(max_cols):
        x = start_x + (col * (default_w + step_x))
        y = start_y + (row * (default_h + step_y))
        rect = (x, y, x + default_w, y + default_h)
        if not overlaps(rect):
            placed_x, placed_y = x, y
            found = True
            break
    if found:
        break

print(json.dumps({
    "type": type_id,
    "title": title,
    "x": placed_x,
    "y": placed_y,
    "width": default_w,
    "height": default_h,
}))
PY
)
    _post "/boards/${bid}/panels" "$payload" | python3 -m json.tool 2>/dev/null
    ;;
  panel:rename)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit panel:rename <board> <panel> <new>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _put "/boards/${bid}/panels/${pid}" "{\"title\":\"$3\"}" | python3 -m json.tool 2>/dev/null
    ;;
  panel:move)
    [[ $# -lt 4 ]] && { echo "Usage: yoloit panel:move <board> <panel> <x> <y>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _put "/boards/${bid}/panels/${pid}" "{\"x\":$3,\"y\":$4}" | python3 -m json.tool 2>/dev/null
    ;;
  panel:resize)
    [[ $# -lt 4 ]] && { echo "Usage: yoloit panel:resize <board> <panel> <w> <h>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _put "/boards/${bid}/panels/${pid}" "{\"width\":$3,\"height\":$4}" | python3 -m json.tool 2>/dev/null
    ;;
  panel:delete)
    [[ $# -lt 2 ]] && { echo "Usage: yoloit panel:delete <board> <panel>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _delete "/boards/${bid}/panels/${pid}" | python3 -m json.tool 2>/dev/null
    ;;
  panel:focus)
    [[ $# -lt 2 ]] && { echo "Usage: yoloit panel:focus <board> <panel>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _put "/boards/${bid}/panels/${pid}" '{"focus":true}' | python3 -m json.tool 2>/dev/null
    ;;

  # ── panel actions ──
  do)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit do <board> <panel> <action> [json-body]" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2"); action=$3
    body="${4:-\{\}}"
    # merge action into body JSON
    merged=$(python3 -c "
import json,sys
b = json.loads(sys.argv[1])
b['action'] = sys.argv[2]
print(json.dumps(b))
" "$body" "$action")
    _post "/boards/${bid}/panels/${pid}/action" "$merged" | python3 -m json.tool 2>/dev/null
    ;;
  run:list)
    [[ $# -lt 2 ]] && { echo "Usage: yoloit run:list <board> <panel>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _post "/boards/${bid}/panels/${pid}/action" '{"action":"list"}' | python3 -m json.tool 2>/dev/null
    ;;
  run:input)
    [[ $# -lt 4 ]] && { echo "Usage: yoloit run:input <board> <panel> <sessionId|id|name> <text> [--enter]" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2"); target="$3"
    shift 3
    append_newline=false
    if [[ "${!#}" == "--enter" ]]; then
      append_newline=true
      set -- "${@:1:$(($# - 1))}"
    fi
    text="$*"
    [[ -z "$text" ]] && { echo "Usage: yoloit run:input <board> <panel> <sessionId|id|name> <text> [--enter]" >&2; exit 1; }
    target_json=$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$target")
    text_json=$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$text")
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"input\",\"sessionId\":${target_json},\"id\":${target_json},\"name\":${target_json},\"text\":${text_json},\"appendNewline\":${append_newline}}" | python3 -m json.tool 2>/dev/null
    ;;
  run:output)
    [[ $# -lt 2 ]] && { echo "Usage: yoloit run:output <board> <panel> [sessionId|id|name]" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    if [[ $# -ge 3 ]]; then
      target="$3"
      target_json=$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$target")
      _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"output\",\"sessionId\":${target_json},\"id\":${target_json},\"name\":${target_json}}" | python3 -m json.tool 2>/dev/null
    else
      _post "/boards/${bid}/panels/${pid}/action" '{"action":"output"}' | python3 -m json.tool 2>/dev/null
    fi
    ;;

  # ── links ──
  links)
    [[ $# -lt 1 ]] && { echo "Usage: yoloit links <board>" >&2; exit 1; }
    bid=$(_encode "$1")
    _get "/boards/${bid}/links" | python3 -m json.tool 2>/dev/null
    ;;
  link:create)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit link:create <board> <from> <to>" >&2; exit 1; }
    bid=$(_encode "$1"); from="$2"; to="$3"
    _post "/boards/${bid}/links" "{\"from\":\"${from}\",\"to\":\"${to}\"}" | python3 -m json.tool 2>/dev/null
    ;;
  link:delete)
    [[ $# -lt 2 ]] && { echo "Usage: yoloit link:delete <board> <link-id>" >&2; exit 1; }
    bid=$(_encode "$1"); lid=$(_encode "$2")
    _delete "/boards/${bid}/links/${lid}" | python3 -m json.tool 2>/dev/null
    ;;

  # Panel color/visibility
  panel:color)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit panel:color <board> <panel> <color|clear>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _put "/boards/${bid}/panels/${pid}" "{\"color\":\"$3\"}" | python3 -m json.tool 2>/dev/null
    ;;
  panel:hide)
    [[ $# -lt 2 ]] && { echo "Usage: yoloit panel:hide <board> <panel>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _put "/boards/${bid}/panels/${pid}" '{"hidden":true}' | python3 -m json.tool 2>/dev/null
    ;;
  panel:show)
    [[ $# -lt 2 ]] && { echo "Usage: yoloit panel:show <board> <panel>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _put "/boards/${bid}/panels/${pid}" '{"hidden":false}' | python3 -m json.tool 2>/dev/null
    ;;
  panel:types)
    [[ $# -lt 1 ]] && { echo "Usage: yoloit panel:types <board>" >&2; exit 1; }
    bid=$(_encode "$1")
    _get "/boards/${bid}/panel-types" | python3 -m json.tool 2>/dev/null
    ;;
  # Link management
  link:style)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit link:style <board> <linkId> <arrow|line> [bezier|straight|elbow]" >&2; exit 1; }
    bid=$(_encode "$1"); lid=$(_encode "$2")
    geo="${4:-bezier}"
    _put "/boards/${bid}/links/${lid}" "{\"style\":\"$3\",\"geometry\":\"${geo}\"}" | python3 -m json.tool 2>/dev/null
    ;;
  link:color)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit link:color <board> <linkId> <color>" >&2; exit 1; }
    bid=$(_encode "$1"); lid=$(_encode "$2")
    _put "/boards/${bid}/links/${lid}" "{\"color\":\"$3\"}" | python3 -m json.tool 2>/dev/null
    ;;
  # Shorthand panel-type commands
  note)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit note <board> <panel> <text>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    shift 2; text="$*"
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"set\",\"text\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$text")}" | python3 -m json.tool 2>/dev/null
    ;;
  note:append)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit note:append <board> <panel> <text>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    shift 2; text="$*"
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"append\",\"text\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$text")}" | python3 -m json.tool 2>/dev/null
    ;;
  note:wrap)
    # Enable auto-height: panel resizes to fit content
    [[ $# -lt 2 ]] && { echo "Usage: yoloit note:wrap <board> <panel>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _post "/boards/${bid}/panels/${pid}/action" '{"action":"wrap"}' | python3 -m json.tool 2>/dev/null
    ;;
  note:nowrap)
    # Disable auto-height: panel keeps fixed height
    [[ $# -lt 2 ]] && { echo "Usage: yoloit note:nowrap <board> <panel>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _post "/boards/${bid}/panels/${pid}/action" '{"action":"nowrap"}' | python3 -m json.tool 2>/dev/null
    ;;
  checklist:add)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit checklist:add <board> <panel> <item>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    shift 2; item="$*"
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"add\",\"text\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$item")}" | python3 -m json.tool 2>/dev/null
    ;;
  checklist:check)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit checklist:check <board> <panel> <item-id|item-text>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    shift 2; target="$*"
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"check\",\"id\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$target"),\"text\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$target")}" | python3 -m json.tool 2>/dev/null
    ;;
  checklist:uncheck)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit checklist:uncheck <board> <panel> <item-id|item-text>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    shift 2; target="$*"
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"uncheck\",\"id\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$target"),\"text\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$target")}" | python3 -m json.tool 2>/dev/null
    ;;
  kanban:columns)
    [[ $# -lt 2 ]] && { echo "Usage: yoloit kanban:columns <board> <panel>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _post "/boards/${bid}/panels/${pid}/action" '{"action":"columns"}' | python3 -m json.tool 2>/dev/null
    ;;
  kanban:add-column)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit kanban:add-column <board> <panel> <column-name>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    shift 2; name="$*"
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"add-column\",\"name\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$name")}" | python3 -m json.tool 2>/dev/null
    ;;
  kanban:rename-column)
    [[ $# -lt 4 ]] && { echo "Usage: yoloit kanban:rename-column <board> <panel> <col-id|name> <new-name>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2"); col="$3"
    shift 3; newname="$*"
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"rename-column\",\"column\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$col"),\"name\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$newname")}" | python3 -m json.tool 2>/dev/null
    ;;
  kanban:remove-column)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit kanban:remove-column <board> <panel> <col-id|name>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    shift 2; col="$*"
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"remove-column\",\"column\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$col")}" | python3 -m json.tool 2>/dev/null
    ;;
  kanban:add-card)
    [[ $# -lt 4 ]] && { echo "Usage: yoloit kanban:add-card <board> <panel> <column> <title>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2"); col="$3"
    shift 3; title="$*"
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"add-card\",\"column\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$col"),\"title\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$title")}" | python3 -m json.tool 2>/dev/null
    ;;
  kanban:move-card)
    [[ $# -lt 4 ]] && { echo "Usage: yoloit kanban:move-card <board> <panel> <cardId> <to-column>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"move-card\",\"cardId\":\"$3\",\"to\":\"$4\"}" | python3 -m json.tool 2>/dev/null
    ;;
  kanban:remove-card)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit kanban:remove-card <board> <panel> <cardId>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"remove-card\",\"cardId\":\"$3\"}" | python3 -m json.tool 2>/dev/null
    ;;
  kanban:update-card)
    [[ $# -lt 4 ]] && { echo "Usage: yoloit kanban:update-card <board> <panel> <cardId> <new-title>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2"); cardId="$3"
    shift 3; title="$*"
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"update-card\",\"cardId\":\"${cardId}\",\"title\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$title")}" | python3 -m json.tool 2>/dev/null
    ;;
  kanban:cards)
    [[ $# -lt 2 ]] && { echo "Usage: yoloit kanban:cards <board> <panel>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _post "/boards/${bid}/panels/${pid}/action" '{"action":"cards"}' | python3 -m json.tool 2>/dev/null
    ;;
  play)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit play <board> <panel> <file-or-url>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    src="$3"
    name=$(basename "$src")
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"add\",\"path\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$src"),\"name\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$name")}" | python3 -m json.tool 2>/dev/null
    sleep 0.1
    _post "/boards/${bid}/panels/${pid}/action" '{"action":"play"}' | python3 -m json.tool 2>/dev/null
    ;;
  web:open)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit web:open <board> <panel> <url>" >&2; exit 1; }
    bid=$(_encode "$1"); pid=$(_encode "$2")
    _post "/boards/${bid}/panels/${pid}/action" "{\"action\":\"open\",\"url\":\"$3\"}" | python3 -m json.tool 2>/dev/null
    ;;
  board:translate)
    [[ $# -lt 3 ]] && { echo "Usage: yoloit board:translate <board> <x> <y>" >&2; exit 1; }
    bid=$(_encode "$1")
    _put "/boards/${bid}/viewport" "{\"x\":$2,\"y\":$3}" | python3 -m json.tool 2>/dev/null
    ;;

  # ── help ──
  help|--help|-h)
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo "Run 'yoloit help' for usage." >&2
    exit 1
    ;;
esac
