# ── Registry: namespace prefixes (one definition per namespace) ───────
# Algorithm: namespace_prefix:first_letters_of_each_action_word
# Example: "checklist:add-item" → "cl:ai"
# Override per command via "alias_override" field.
# Only namespaces listed in ALIAS_ENABLED_NAMESPACES get auto-generated short aliases.
# Other namespaces can still have manual "aliases" in their command definition.
NAMESPACE_PREFIXES = {
    "app":       "app",
    "board":     "b",
    "panel":     "p",
    "run":       "r",
    "timer":     "t",
    "models":    "m",
    "yolochat":  "yc",
    "link":      "lk",
    "note":      "n",
    "checklist": "cl",
    "kanban":    "k",
    "playlist":  "pl",
    "webpage":   "w",
    "widget":    "wg",
}

# Only these namespaces get automatically generated short aliases.
# Add a namespace here when you want the algorithm to kick in.
ALIAS_ENABLED_NAMESPACES = {"note", "checklist", "kanban"}

def auto_alias(cmd):
    """Auto-generate short alias from command name using namespace prefix + action initials.
    Only applies to ALIAS_ENABLED_NAMESPACES or commands with alias_override."""
    name = cmd["name"]
    if "alias_override" in cmd:
        return cmd["alias_override"]
    if ":" not in name:
        return None
    ns, action = name.split(":", 1)
    if ns not in ALIAS_ENABLED_NAMESPACES:
        return None
    prefix = NAMESPACE_PREFIXES.get(ns)
    if not prefix:
        return None
    # First letter of each "-"-separated word in the action part
    abbrev = "".join(w[0] for w in action.split("-") if w)
    alias = f"{prefix}:{abbrev}"
    return alias if alias != name else None

def resolve_aliases(commands):
    """Build alias list for each command; detect and report collisions."""
    alias_map = {}   # alias → canonical name
    for c in commands:
        aliases = list(c.get("aliases", []))  # keep any manual aliases
        auto = auto_alias(c)
        if auto and auto not in aliases and auto != c["name"]:
            aliases.append(auto)
        # Collision detection
        clean = []
        for a in aliases:
            if a in alias_map and alias_map[a] != c["name"]:
                import sys as _sys
                print(f"⚠️  Alias collision: '{a}' claimed by '{alias_map[a]}' and '{c['name']}'", file=_sys.stderr)
            else:
                alias_map[a] = c["name"]
                clean.append(a)
        c = dict(c)
        c["aliases"] = clean
        yield c

commands = list(resolve_aliases(commands))

by_group = defaultdict(list)
for c in commands:
    by_group[c["group"]].append(c)

group_order = ["app", "board", "panel", "run", "timer", "models", "yolochat", "link", "note", "checklist", "kanban", "playlist", "webpage"]

def params_inline(c):
    if not c["params"]:
        return "none"
    return ", ".join([f'{p[0]}{"*" if p[2] else ""}' for p in c["params"]])

def param_to_key(name):
    raw = name.strip()
    if raw.startswith("--"):
        raw = raw.split()[0].lstrip("-")
    key = raw.replace("|", "_or_")
    key = re.sub(r"[^a-zA-Z0-9_]+", "_", key)
    key = re.sub(r"_+", "_", key).strip("_").lower()
    return key or "arg"

if fmt == "short":
    print("yoloit help (short)")
    print("Use: yoloit help --format [short|detailed|mermaid|mermaid_short|tools|registry]")
    print("Board and panel are optional in note/checklist/kanban commands — uses active board/panel.")
    for g in group_order:
        if not by_group[g]:
            continue
        print(f"\n{g}:")
        for c in by_group[g]:
            aliases = c.get("aliases", [])
            alias_str = f'  [aliases: {", ".join(aliases)}]' if aliases else ""
            print(f'  {c["name"]} — {c["description"]}{alias_str}')
            if c["params"]:
                print(f'    params: {params_inline(c)}')
            print(f'    ex: {c["example"]}')
elif fmt == "detailed":
    print("yoloit help (detailed)\n")
    for c in commands:
        aliases = c.get("aliases", [])
        print(f'Command: {c["name"]}')
        if aliases:
            print(f'Aliases: {", ".join(aliases)}')
        print(f'Description: {c["description"]}')
        if c["params"]:
            print("Parameters:")
            for name, desc, req in c["params"]:
                reqs = "required" if req else "optional"
                print(f"  - {name} ({reqs}): {desc}")
        fmt_parts = [c["name"]]
        for name, _, req in c["params"]:
            fmt_parts.append(f'<{name}>' if req else f'[{name}]')
        print(f'CLI command format: yoloit {" ".join(fmt_parts)}')
        print(f'Example: {c["example"]}\n')
elif fmt == "mermaid":
    print("graph TD")
    print("  root[yoloit help]")
    for g in group_order:
        if not by_group[g]:
            continue
        gid = f"g_{g}"
        print(f'  root --> {gid}["{g}"]')
        for i, c in enumerate(by_group[g]):
            cid = f"{gid}_{i}"
            aliases = c.get("aliases", [])
            alias_str = f'<br/>aliases: {", ".join(aliases)}' if aliases else ""
            label = f'{c["name"]}{alias_str}<br/>{c["description"]}'
            if c["params"]:
                label += f'<br/>params: {params_inline(c)}'
            label = label.replace('"', '\\"')
            print(f'  {gid} --> {cid}["{label}"]')
elif fmt == "mermaid_short":
    print("graph LR")
    print("  root[yoloit]")
    for g in group_order:
        if not by_group[g]:
            continue
        gid = f"g_{g}"
        print(f'  root --> {gid}(("{g}"))')
        for i, c in enumerate(by_group[g]):
            cid = f"{gid}_{i}"
            aliases = c.get("aliases", [])
            name_str = c["name"]
            if aliases:
                name_str += f' · {" · ".join(aliases)}'
            name_str = name_str.replace('"', '\\"')
            print(f'  {gid} --> {cid}["{name_str}"]')
elif fmt == "tools":
    tools = []
    for c in commands:
        props = {}
        required = []
        for name, desc, req in c["params"]:
            key = param_to_key(name)
            props[key] = {"type": "string", "description": desc}
            if req:
                required.append(key)
        schema = {
            "type": "object",
            "properties": props,
            "additionalProperties": False,
        }
        if required:
            schema["required"] = required
        tools.append(
            {
                "name": c["name"],
                "aliases": c.get("aliases", []),
                "description": c["description"],
                "inputSchema": schema,
            }
        )
    print(json.dumps({"tools": tools}, ensure_ascii=False, indent=2))
elif fmt == "registry":
    # Machine-readable: all commands + auto-aliases, used by 'validate'
    out = []
    for c in commands:
        out.append({
            "name": c["name"],
            "group": c["group"],
            "aliases": c.get("aliases", []),
        })
    print(json.dumps(out, ensure_ascii=False, indent=2))
else:
    print(f"Unknown format: {fmt}", file=sys.stderr)
    sys.exit(2)
PYEOF
}

_parse_help_format() {
  local format="short"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --format|-f)
        format="${2:-short}"
        shift 2
        ;;
      short|detailed|mermaid|mermaid_short|tools|registry)
        format="$1"
        shift
        ;;
      *)
        shift
        ;;
    esac
  done
  echo "$format"
}

usage() {
  local format="${1:-short}"
  _render_help "$format"
}

# ── Helpers ────────────────────────────────────────────────────────────

_encode() { python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$1"; }

_auto_panel() {
  local bid=$1 type=$2 title=$3 state=${4:-}
  local body="{\"type\":\"${type}\",\"title\":$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$title")"
  [[ -n "$state" ]] && body+=",\"state\":${state}"
  body+="}"
  local created
  created=$(_post "/boards/${bid}/panels" "$body")
  python3 -c "import json,sys; d=json.loads(sys.stdin.read() or '{}'); print((d.get('panel') or {}).get('id',''))" <<<"$created"
}

# ── Smart board/panel resolution ──────────────────────────────────────

# Returns active board raw name/id: explicit arg → state.json → API active board
_require_board() {
  local explicit="${1:-}"
  if [[ -n "$explicit" ]]; then echo "$explicit"; return; fi
  local from_state
  from_state=$(_board "")
  if [[ -n "$from_state" ]]; then echo "$from_state"; return; fi
  _resolve_base 2>/dev/null || true
  if [[ -n "$BASE" ]]; then
    local name
    name=$(python3 -c "
import json, sys
d = json.loads(sys.stdin.read() or '{}')
b = d.get('board') or {}
print(b.get('name') or b.get('id') or '')
" <<<"$(_get "/active-board" 2>/dev/null)" 2>/dev/null || echo "")
    [[ -n "$name" ]] && { echo "$name"; return; }
  fi
  echo "Error: no board specified and no active board found. Use 'yoloit board:use <name>'." >&2
  exit 1
}

# Find existing panel of given type (optionally matching title hint), or create one.
# Usage: _smart_panel <encoded-bid> <type> [title-hint]
# Returns panel id (raw, not encoded)
_smart_panel() {
  local bid=$1 type=$2 hint="${3:-}"
  local panels_json existing=""
  panels_json=$(_get "/boards/${bid}/panels" 2>/dev/null)
  # Match by title hint first
  if [[ -n "$hint" ]]; then
    existing=$(python3 -c "
import json, sys
d = json.loads(sys.stdin.read() or '{}')
hint = sys.argv[1].lower(); typ = sys.argv[2]
for p in d.get('panels') or []:
    if not p.get('hidden') and (p.get('title','').lower() == hint or p.get('id','').lower() == hint):
        print(p.get('id','')); break
" "$hint" "$type" <<<"$panels_json" 2>/dev/null)
  fi
  # Fallback: first visible panel of matching type
  if [[ -z "$existing" ]]; then
    existing=$(python3 -c "
import json, sys
d = json.loads(sys.stdin.read() or '{}')
typ = sys.argv[1]
for p in d.get('panels') or []:
    if not p.get('hidden') and p.get('type','') == typ:
        print(p.get('id','')); break
" "$type" <<<"$panels_json" 2>/dev/null)
  fi
  if [[ -n "$existing" ]]; then
    echo "$existing"
  else
    # Create a new panel with sensible title
    local display="${hint:-${type##*.}}"
    display=$(python3 -c "import sys; print(sys.argv[1].capitalize())" "$display")
    _auto_panel "$bid" "$type" "$display"
  fi
}

